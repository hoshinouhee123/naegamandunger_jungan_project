      m_Calls: []
  m_text: "\uAC8C\uC784\uC744 \uD074\uB9AC\uC5B4 \uD558\uC168\uAD70\uC694!\n\uC9C0\uAE08
    \uC62C\uB77C\uC624\uB294 \uD14D\uC2A4\uD2B8\uB294 \uC5D4\uB529 \uD06C\uB808\uB527
    \uC5F0\uCD9C\uC744 \n\uD14C\uC2A4\uD2B8 \uD558\uAE30 \uC704\uD55C \uD14D\uC2A4\uD2B8\uC77C\uAC81\uB2C8\uB2E4.
    \n\uC544\uB9C8\uB3C4.\n \uC0AC\uC2E4 \uC5D4\uB529 \uC5F0\uCD9C\uC744 \uC774\uC058\uAC8C
    \uB123\uACE0\uC2F6\uACE0 \n\uC6D0\uB798 \uACC4\uD68D\uC73C\uB860 \uC560\uB2C8\uBA54\uC774\uC158\uC744
    \uADF8\uB824\uC11C \n\uC601\uC0C1\uC744 \uC7AC\uC0DD\uD558\uB294\uAC70\uC600\uB294\uB370
    \uC5B4\uB9BC\uB3C4\uC5C6\uB124\uC694. \n\uADF8\uB9BC\uC2E4\uB825\uB3C4 \uBD80\uC871\uD558\uACE0
    \uADF8\uB798\uC11C \uADF8\uB0E5 ai\uADF8\uB9BC \uC77C\uB7EC\uC2A4\uD2B8\uB85C\n
    \uC5D4\uB529 \uC77C\uB7EC\uC2A4\uD2B8 \uB300\uCDA9 \uB54C\uC6CC\uBD05\uB2C8\uB2E4.
    \n\uC0AC\uC2E4 \uC2A4\uD1A0\uB9AC \uC124\uBA85\uC774 \uAC8C\uC784 \uB0B4\uC5D0
    \uC880 \uBD80\uC871\uD55C\n\uB290\uB08C\uC778\uB370\n\uC2A4\uD1A0\uB9AC\uB294
    \uB300\uCDA9 \uD0D0\uD5D8\uAC00 \uC5EC\uC8FC\uC778\uACF5\uC774 \uC124\uC0B0 \uD0D0\uD5D8\uD558\uB2E4\n\uAF2D\uB300\uAE30\uC5D0\uC11C
    \uC124\uB140\uB791 \uC2F8\uC6B0\uAC8C \uB418\uB294 \uB0B4\uC6A9\uC785\uB2C8\uB2E4.\n\uC2A4\uD1A0\uB9AC
    \uAC1C\uC5F0\uC131\uC740 \uBD80\uC871\uD558\uC9C0\uB9CC \uADF8\uB9CC\uD07C\n\uCF54\uB4DC\uB97C
    \uC774\uD574\uD558\uB294\uB370 \uC9D1\uC911\uD558\uACE0 \uC2F6\uC5C8\uC5B4\uC694.\n\uC0AC\uC2E4
    \uC5D0\uC14B \uC9C1\uC811 \uADF8\uB9AC\uB2E4\uAC00\n\uB108\uBB34 \uD798\uB4E4\uACE0
    \uC774\uB7EC\uB2E4\uAC04 \uC791\uC5C5 \uC2DC\uC791\uB3C4\n\uBABB\uD560\uAC83
    \uAC19\uC544\uC11C \uADF8\uB0E5 ai\uD55C\uD14C \uB9E1\uAE30\uACE0\n\uC791\uC5C5
    \uBA3C\uC800 \uC2DC\uC791\uD558\uC790\uD574\uC11C \uC774\uB807\uAC8C\n\uB2A6\uAC8C
    \uC791\uC5C5\uD558\uAC8C \uB418\uC5C8\uC2B5\uB2C8\uB2E4.\n\uCF54\uB4DC\uB294
    ai\uD55C\uD14C \uC880 \uB3C4\uC640\uB2EC\uB77C\uACE0 \uD558\uAE34\uD588\uC9C0\uB9CC
    \uC5B4\uB290\uC815\uB3C8 \uC81C\uAC00 \uC9C1\uC811 \uCF54\uB4DC \uC9F0\uC5B4\uC694.\n\uC800
    \uC9C4\uC9DC \uC5F4\uC2EC\uD788\uD588\uC5B4\uC694\n\uC5F4\uC2EC\uD788\uD558\uBA74\uC11C
    \uC0C8\uBCBD\uAE4C\uC9C0 \uC791\uC5C5\uD558\uACE0\n\uC5D4\uB4DC\uD544\uB4DC \uC5C5\uB383
    \uB098\uC654\uB2E4\uACE0\uD588\uB294\uB370\n\uC544\uC9C1 \uAC8C\uC784 \uC2DC\uC791
    \uC81C\uB300\uB85C \uBABB\uD588\uC5B4\uC694\n\uC544\uBB34\uD2BC\n\uC800 \uC815\uB9D0
    \uC5F4\uC2EC\uD788 \uD588\uC2B5\uB2C8\uB2E4 \uAD50\uC218\uB2D8.\n"
